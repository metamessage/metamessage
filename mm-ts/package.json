{
  "name": "meta-message-ts",
  "version": "0.1.0",
  "description": "TypeScript implementation of MetaMessage",
  "type": "module",
  "main": "dist/mm/index.js",
  "types": "dist/mm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mm/index.js",
      "types": "./dist/mm/index.d.ts"
    },
    "./jsonc": {
      "import": "./dist/jsonc/index.js",
      "types": "./dist/jsonc/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "dev": "tsc --watch"
  },
  "keywords": [
    "metamessage",
    "binary",
    "encoding",
    "decoding",
    "typescript"
  ],
  "author": "MetaMessage Team",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.4.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}